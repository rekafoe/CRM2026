# Базовый URL API (если не задан — используется /api, на Vercel это rewrite на Railway).
# VITE_API_URL=https://xxxx.up.railway.app/api

# Опционально: переопределить хост только для upload (если не printcrm / не тот же Railway, что в vercel.json).
# На *.vercel.app с относительным /api без env upload и так уходит напрямую на crm2026-production.up.railway.app (см. api/client.ts).
# VITE_UPLOAD_API_URL=https://xxxx.up.railway.app/api
