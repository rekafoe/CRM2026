# Базовый URL API (если не задан — используется /api, на Vercel это rewrite на Railway).
# VITE_API_URL=https://xxxx.up.railway.app/api

# Только для multipart upload (продукт/категория/подтип): полный https на тот же бэкенд.
# Нужен, если VITE_API_URL не задан и запросы идут на printcrm.vercel.app/api — rewrite Vercel часто даёт 400 на POST FormData.
# VITE_UPLOAD_API_URL=https://xxxx.up.railway.app/api
