# Server
PORT=8080
# CORS: один или несколько origin через запятую/точку с запятой/перенос строки. Схема + хост (без пути).
# Обязательно добавьте каждый домен фронта (Vercel preview и production), иначе браузер заблокирует запросы (CORS).
# Пример: https://mirfotocrm.vercel.app,https://printcrm.vercel.app,http://localhost:5173
CORS_ORIGIN=https://printcore.by,https://mirfotocrm.vercel.app,https://crm-2026-llk4uk0ed-rekafoes-projects.vercel.app,http://localhost:5173
NODE_ENV=production

# Шаблоны документов (акт, счёт): путь к папке внутри volume. Без этой переменной загруженные шаблоны теряются при редеплое (Railway и др.).
# DOCUMENT_TEMPLATES_DIR=/data/document-templates

# Публичный базовый URL API: интеграции, витрина (относительные /api/uploads/...), ссылки «отписаться» и пиксель открытия писем
# (GET /api/mail/unsubscribe?token=..., GET /api/mail/track/open/:token). В production укажите https://ваш-API.
# Пример: PUBLIC_API_BASE_URL=https://xxxx.up.railway.app
# PUBLIC_API_BASE_URL=

# Картинки продуктов/категорий/подтипов: путь к папке внутри volume. Без UPLOADS_DIR изображения теряются при редеплое.
# UPLOADS_DIR=/data/uploads
# UPLOADS_PUBLIC=true — картинки доступны всем без ключа (для img src на сайте). Если false/не задано — нужен WEBSITE_ORDER_API_KEY.
# UPLOAD_MAX_FILE_SIZE_BYTES=26214400 — лимит одного файла (multer и проверки в routes), по умолчанию 25 МБ.
# Файлы заказов (макеты клиентов) хранятся в uploads/orders/ и НЕ отдаются через /api/uploads — только через авторизованный download.
SHOW_ERROR_STACK=false
LOG_LEVEL=INFO

# Security
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h
# См. docs/SECURITY.md: БД, бэкапы, CORS, токены. Не храните data.db в каталоге публичных загрузок.
# REQUEST_BODY_LIMIT=2mb — максимум тела JSON (по умолчанию 2mb)
# Общий лимит на IP (гость / без Bearer). GET /api/uploads/* и /uploads/* не считаются — иначе ломается витрина с картинками.
# RATE_LIMIT_WINDOW_MS — скользящее окно: по умолчанию 30 с (счётчик обнуляется каждые 30 с, без долгой блокировки).
# С Bearer — лимит RATE_LIMIT_AUTH_MAX за то же окно.
RATE_LIMIT_MAX=150
RATE_LIMIT_WINDOW_MS=30000
RATE_LIMIT_AUTH_MAX=500

# Публичный API заказов с сайта (POST /api/orders/from-website). Заголовок X-API-Key или Authorization: Bearer <key>.
# Если не задан — эндпоинт возвращает 503.
# WEBSITE_ORDER_API_KEY=your-website-api-key

# Bootstrap admin (создаётся автоматически при первом старте, если таблица users пустая)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Администратор

# Database
# По умолчанию можно хранить SQLite в WORKDIR контейнера/проекта (Railway создаст файл автоматически)
# Если нужна персистентность — подключите Railway Volume и укажите путь внутри volume, например: /data/data.db
DB_FILE=data.db

# Monitoring & Notifications
STOCK_MONITORING_ENABLED=true
STOCK_CHECK_INTERVAL=30
LOW_STOCK_THRESHOLD=120
CRITICAL_STOCK_THRESHOLD=100
DEFAULT_ORDER_EMAIL=ops@example.com

# Auto Ordering
AUTO_ORDER_ENABLED=false
AUTO_ORDER_THRESHOLD=80
MIN_ORDER_AMOUNT=100
MAX_ORDER_AMOUNT=10000
ORDER_FREQUENCY=weekly
PREFERRED_DELIVERY_DAYS=1,2,3,4,5
AUTO_APPROVE_ORDERS=false
ORDER_NOTIFICATIONS_ENABLED=true

# Telegram Bot
# Включение бота. Доставка апдейтов: либо long polling (как в index.ts), либо вебхук (setWebhook) — оба варианта одновременно в Telegram нельзя.
# Локальная отладка: TELEGRAM_ENABLED=true и polling, в BotFather /deleteWebhook (или POST /api/notifications/telegram/webhook/set с removeWebhook: true).
# Прод: HTTPS URL → POST /api/notifications/telegram/webhook. TELEGRAM_USE_WEBHOOK=true — не стартовать getUpdates в процессе (только вебхук).
# TELEGRAM_USE_WEBHOOK=false
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=
# Опционально: тот же секрет должен быть в setWebhook; Telegram пришлёт заголовок X-Telegram-Bot-Api-Secret-Token
# TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
TELEGRAM_POLL_INTERVAL_MS=5000
TELEGRAM_POLL_TIMEOUT_MS=30000
TELEGRAM_LONGPOLL_TIMEOUT_SEC=25

# Telegram Mini App (сессия после POST /api/miniapp/auth)
# Секрет подписи токена mapp1.* (по умолчанию JWT_SECRET)
# MINIAPP_SESSION_SECRET=
# Срок жизни initData при проверке (сек), по умолчанию 86400 (24 ч)
# MINIAPP_INIT_DATA_MAX_AGE_SEC=86400
# TTL сессии мини-апа (сек), по умолчанию 604800 (7 дней)
# MINIAPP_SESSION_TTL_SEC=86400
# API: GET/POST …/orders…; GET /api/miniapp/orders/:orderId/files/:fileId — скачивание вложения (Bearer mapp1…; миграция orders.telegram_chat_id)
# Уведомления в личку о смене статуса для заказов source=mini_app: тот же TELEGRAM_BOT_TOKEN и включённый бот (см. TELEGRAM_* выше)
# Публичная страница: GET /miniapp (тест auth + /me). Кнопка /miniapp в боте:
# MINIAPP_WEBAPP_URL=https://ваш-api.example.com/miniapp
# Если API на другом хосте, чем HTML — база для fetch (иначе = Host запроса к /miniapp):
# MINIAPP_API_BASE_URL=https://ваш-api.example.com
# Опционально: id категории (product_categories.id) — в каталоге мини-апа только товары этой категории; не задано = весь forSite
# MINIAPP_CATALOG_CATEGORY_ID=

# Базовый URL сайта для кнопок-ссылок в Telegram (команда /poligrafy). По умолчанию https://printcore.by
# PRINTCORE_PUBLIC_SITE_BASE=https://printcore.by

# Исходящая почта (очередь mail_jobs, nodemailer). Без SMTP_HOST и SMTP_FROM воркер не стартует.
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=robot@yourdomain.by
# SMTP_PASS=app-password
# SMTP_FROM="Printcore <robot@yourdomain.by>"
# Таймаут соединения с SMTP (мс, 5000–120000; по умолчанию 20000). Уменьшает «вечное» ожидание test.
# SMTP_TIMEOUT_MS=20000
# При Connection timeout / ETIMEDOUT к smtp.gmail.com и т.д. попробуйте принудительно IPv4 (часто Docker/хостинг):
# SMTP_IP_FAMILY=4
# Опционально: адрес From для job_type=marketing; если не задан — используется SMTP_FROM
# SMTP_FROM_MARKETING="Printcore <news@yourdomain.by>"
# Важно: записи MX в DNS нужны для приёма почты на домен. Исходящая почта из CRM — через SMTP_*
# (часто smtp.gmail.com / smtp хостинга; порт 587 + STARTTLS или 465 + SSL, не «голый» MX-хост).
# Пиксель открытия в HTML маркетинговых писем (1×1, только при заданном PUBLIC_API_BASE_URL). true/1 — включить
# MAIL_OPEN_TRACKING=false
# MAIL_OUTBOX_ENABLED=true
# MAIL_OUTBOX_INTERVAL_MS=15000
# Массовая рассылка: см. тот же PUBLIC_API_BASE_URL; лимит адресов за broadcast; пауза между письмами в воркере (мс)
# MAIL_MARKETING_BROADCAST_MAX=500
# MAIL_MARKETING_SEND_DELAY_MS=2000

# SMS (order status / manual; провайдер log — только в лог, http — тестовый JSON POST)
# SMS_ENABLED=true
# SMS_PROVIDER=log
# SMS_DEBOUNCE_SECONDS=120
# SMS_WORKER_INTERVAL_MS=20000
# Время по Europe/Minsk: окно, вне него — отложенная автоотправка; ручная — 409
# SMS_QUIET_HOURS_START=8:30
# SMS_QUIET_HOURS_END=20:00
# HTTP-провайдер (когда появится спека): SMS_HTTP_URL= SMS_HTTP_METHOD=POST
# SMS_HTTP_BODY={"phone":"{{phone}}","message":"{{text}}"}
# SMS_HTTP_HEADERS={}

# Analytics
SENTRY_DSN=

# Пересчёт ЗП: секрет для GET/POST /api/earnings/recalculate?secret=XXX (опционально)
# Если не задан — доступ только для admin. Если задан — можно вызвать без авторизации.
# RECALC_EARNINGS_SECRET=your-random-secret
